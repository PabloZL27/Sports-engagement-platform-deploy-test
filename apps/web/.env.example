# =============================================================================
# ESCENARIO A: Proxy de Vite (recomendado para localhost)
# =============================================================================
# - NO definas VITE_API_BASE_URL (debe quedar vacío para usar rutas relativas)
# - Las peticiones van a /api/... y el proxy de Vite las reenvía al gateway
# - Así evitas CORS y todo funciona en localhost
#
# VITE_PROXY_TARGET = dónde está el gateway
#   Por defecto: localhost:8081 (cuando corres docker-compose desde infra/)
#   Si el gateway está en otra máquina: VITE_PROXY_TARGET=http://10.14.255.82:8081
# =============================================================================
#
# =============================================================================
# VOICE AGENT (ElevenLabs)
# =============================================================================
# - Crea .env.local con: VITE_ELEVENLABS_AGENT_ID=agent_xxx
# - Obtén el ID desde el dashboard de ElevenLabs
# =============================================================================
# VITE_ELEVENLABS_AGENT_ID=

# =============================================================================
# ADMIN STORE SERVICE
# =============================================================================
# Opción A — Docker completo (gateway en 8081): descomentar la siguiente línea
# VITE_ADMIN_STORE_URL=http://localhost:8081/admin-store
#
# Opción B — Servicio corriendo directo en local (npm run dev en admin-store-service):
# VITE_ADMIN_STORE_URL=http://localhost:4013
