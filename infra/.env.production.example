# Production environment example
# Replace with your managed Postgres/Supabase provider.

PROFILE_DB_URL=postgresql://profile_user:password@your-db-host:5432/profile_db
COMMUNITY_DB_URL=postgresql://community_user:password@your-db-host:5432/community_db
MATCHES_DB_URL=postgresql://matches_user:password@your-db-host:5432/matches_db

# Supabase/Auth/Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key