# Production environment example
# Replace with your managed Postgres/Supabase provider.

PROFILE_DB_URL=postgresql://profile_user:password@your-db-host:15432/profile_db
COMMUNITY_DB_URL=postgresql://community_user:password@your-db-host:15432/community_db
MATCHES_DB_URL=postgresql://matches_user:password@your-db-host:15432/matches_db
ROOMS_DB_URL=postgresql://rooms_user:password@your-db-host:15432/rooms_db
ANALYTICS_DB_URL=postgresql://analytics_user:password@your-db-host:15432/analytics_db
HISTORY_DB_URL=postgresql://history_user:password@your-db-host:15432/history_db
CARDS_DB_URL=postgresql://cards_user:password@your-db-host:15432/cards_db
OFFSEASON_DB_URL=postgresql://offseason_user:password@your-db-host:15432/offseason_db
NEWS_DB_URL=postgresql://news_user:password@your-db-host:15432/news_cache
FEEDBACKMAIL_DB_URL=postgresql://feedback_user:password@your-db-host:15432/feedback_db
WAR_ROOM_DB_URL=postgresql://war_room_user:password@your-db-host:15432/feedback_db

# Supabase / Auth / Storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=

# External APIs
GETXAPI_KEY=
NEWS_API_KEY=

SUPABASE_DOCKER_NETWORK=your_supabase_network_name

COMMUNITY_SERVICE_URL=http://community-service:4001
PROFILE_SERVICE_URL=http://profile-service:4006
STORE_SERVICE_URL=http://store-service:4005

NEWS_QUERY=tennessee-titans
NEWS_PAGE_SIZE=20
NEWS_SORT=publishedAt
NEWS_LANGUAGE=en
NEWS_DB_MANAGE_SCHEMA=false

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODERATION_MODEL=omni-moderation-latest
